{
  "sourceLanguage" : "en",
  "strings" : {
    "PasswordRuleDescription" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Note: The new password must include three types of characters: numbers, letters, and symbols. Symbols include: !, @, #, ¥, %, &, (), *, ~, ^. Minimum 8 characters, maximum 20 characters."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "说明：新密码需包含以下三种类型，数字、字母、字符，其中字符包括：！、@、#、¥、%、&，（）、*、~、^、 最少8位，最多20位。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "說明：新密碼需包含以下三種類型，數字、字母、字符，其中字符包括：！、@、#、¥、%、&，（）、*、~、^、 最少8位，最多20位。"
          }
        }
      }
    },
    "两次输入密码不一致" : {
